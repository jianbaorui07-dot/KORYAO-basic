{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://starbridge.local/schemas/vector_patch.v1.schema.json",
  "title": "StarBridge Vector Patch",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "patch_id", "scene_id", "round", "mode", "operations"],
  "properties": {
    "schema_version": { "const": "starbridge.vector-patch.v1" },
    "patch_id": { "$ref": "#/$defs/id" },
    "scene_id": { "$ref": "#/$defs/id" },
    "round": { "type": "integer", "minimum": 1, "maximum": 3 },
    "mode": { "const": "diff_only" },
    "operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["operation", "target_object_id", "reason"],
        "properties": {
          "operation": { "enum": ["update_geometry", "update_style", "update_text", "remove_object"] },
          "target_object_id": { "$ref": "#/$defs/id" },
          "reason": { "type": "string", "minLength": 1, "maxLength": 512 },
          "changes": {
            "type": "object",
            "maxProperties": 32,
            "propertyNames": { "enum": ["x", "y", "width", "height", "rx", "cx", "cy", "r", "rx_radius", "ry_radius", "x1", "y1", "x2", "y2", "points", "commands", "text", "font_family", "font_size", "text_anchor", "style"] }
          },
          "preserve": { "type": "array", "items": { "enum": ["layer", "fill", "stroke", "text", "passing_geometry"] }, "uniqueItems": true }
        }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$" }
  }
}
