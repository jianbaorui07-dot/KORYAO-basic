{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://starbridge.local/schemas/color_vector_repair.v1.schema.json",
  "title": "StarBridge Color Vector Repair Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "bridge",
    "action",
    "schema_version",
    "reference_id",
    "reference_authorized",
    "verdict",
    "repair_round",
    "max_repair_rounds",
    "current_settings",
    "next_settings",
    "changes",
    "addressed_findings",
    "unresolved_findings",
    "requires_execute",
    "requires_user_review",
    "suggested_next_tool",
    "next_execute_template",
    "runtime_requirements",
    "iteration_control",
    "post_execute_compare",
    "warnings",
    "safety",
    "dry_run",
    "side_effects"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "bridge": { "const": "illustrator" },
    "action": { "const": "color_vectorize_repair_plan" },
    "schema_version": { "const": "starbridge.color-vector-repair.v1" },
    "reference_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"
    },
    "reference_authorized": { "type": "boolean" },
    "verdict": {
      "enum": ["planned", "pass_through", "needs_user", "blocked"]
    },
    "repair_round": { "type": "integer", "minimum": 1, "maximum": 3 },
    "max_repair_rounds": { "type": "integer", "minimum": 1, "maximum": 3 },
    "current_settings": { "$ref": "#/$defs/settings" },
    "next_settings": { "$ref": "#/$defs/settings" },
    "changes": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["parameter", "previous", "next", "reason_code"],
        "properties": {
          "parameter": {
            "enum": [
              "max_colors",
              "path_fitting",
              "min_area",
              "preprocess_blur",
              "photoshop_preprocess",
              "normalize_srgb",
              "median_radius"
            ]
          },
          "previous": { "type": ["number", "boolean"] },
          "next": { "type": ["number", "boolean"] },
          "reason_code": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{0,63}$"
          }
        }
      }
    },
    "addressed_findings": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/finding_code" }
    },
    "unresolved_findings": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/finding_code" }
    },
    "requires_execute": { "type": "boolean" },
    "requires_user_review": { "type": "boolean" },
    "suggested_next_tool": {
      "oneOf": [
        { "const": "illustrator.color_vectorize_execute" },
        { "type": "null" }
      ]
    },
    "next_execute_template": {
      "oneOf": [
        { "$ref": "#/$defs/execute_template" },
        { "type": "null" }
      ]
    },
    "runtime_requirements": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "authorized_source_file",
          "write_confirmation",
          "export_confirmation"
        ]
      }
    },
    "iteration_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executing_round",
        "max_repair_rounds",
        "remaining_rounds_after_execute",
        "compare_after_execute",
        "next_repair_round",
        "stop_after_compare_if_failed"
      ],
      "properties": {
        "executing_round": { "type": "integer", "minimum": 1, "maximum": 3 },
        "max_repair_rounds": { "type": "integer", "minimum": 1, "maximum": 3 },
        "remaining_rounds_after_execute": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        },
        "compare_after_execute": { "type": "boolean" },
        "next_repair_round": {
          "type": ["integer", "null"],
          "minimum": 2,
          "maximum": 3
        },
        "stop_after_compare_if_failed": { "type": "boolean" }
      }
    },
    "post_execute_compare": {
      "oneOf": [
        { "$ref": "#/$defs/post_execute_compare" },
        { "type": "null" }
      ]
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inputs_sanitized",
        "reads_files",
        "writes_files",
        "starts_adobe",
        "arbitrary_script",
        "quality_gates_relaxed",
        "bounded_repair",
        "visual_review_required"
      ],
      "properties": {
        "inputs_sanitized": { "const": true },
        "reads_files": { "const": false },
        "writes_files": { "const": false },
        "starts_adobe": { "const": false },
        "arbitrary_script": { "const": false },
        "quality_gates_relaxed": { "const": false },
        "bounded_repair": { "const": true },
        "visual_review_required": { "const": true }
      }
    },
    "dry_run": { "const": true },
    "side_effects": { "const": false }
  },
  "$defs": {
    "finding_code": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,63}$"
    },
    "execute_template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference_id",
        "reference_authorized",
        "source_media_type",
        "strategy",
        "photoshop_preprocess",
        "normalize_srgb",
        "max_dimension",
        "median_radius",
        "max_colors",
        "path_fitting",
        "min_area",
        "preprocess_blur",
        "ignore_white",
        "output_to_swatches",
        "dry_run",
        "confirm_write",
        "confirm_export"
      ],
      "properties": {
        "reference_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"
        },
        "reference_authorized": { "const": true },
        "source_media_type": { "enum": ["image/png", "image/jpeg"] },
        "strategy": { "enum": ["local_illustrator_trace", "hybrid"] },
        "photoshop_preprocess": { "type": "boolean" },
        "normalize_srgb": { "type": "boolean" },
        "max_dimension": { "type": "integer", "minimum": 256, "maximum": 8192 },
        "median_radius": { "type": "integer", "minimum": 0, "maximum": 5 },
        "max_colors": { "type": "integer", "minimum": 2, "maximum": 256 },
        "path_fitting": { "type": "number", "minimum": 0, "maximum": 10 },
        "min_area": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "preprocess_blur": { "type": "number", "minimum": 0, "maximum": 2 },
        "ignore_white": { "type": "boolean" },
        "output_to_swatches": { "type": "boolean" },
        "dry_run": { "const": true },
        "confirm_write": { "const": false },
        "confirm_export": { "const": false }
      }
    },
    "compare_argument_template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference_id",
        "reference_authorized",
        "max_dimension",
        "background_threshold",
        "soft_exit"
      ],
      "properties": {
        "reference_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"
        },
        "reference_authorized": { "const": true },
        "max_dimension": { "const": 512 },
        "background_threshold": { "const": 24 },
        "soft_exit": { "const": true }
      }
    },
    "post_execute_compare": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "argument_template",
        "runtime_requirements",
        "on_pass",
        "on_repair_needed",
        "on_blocked",
        "next_repair_round"
      ],
      "properties": {
        "tool": { "const": "illustrator.color_vectorize_compare" },
        "argument_template": { "$ref": "#/$defs/compare_argument_template" },
        "runtime_requirements": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "enum": [
              "authorized_reference_file",
              "sandbox_preview_file",
              "trace_evidence"
            ]
          }
        },
        "on_pass": { "const": "complete" },
        "on_repair_needed": {
          "enum": ["plan_next_repair", "stop_for_user"]
        },
        "on_blocked": { "const": "stop_for_user" },
        "next_repair_round": {
          "type": ["integer", "null"],
          "minimum": 2,
          "maximum": 3
        }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace", "preprocess"],
      "properties": {
        "trace": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_colors",
            "path_fitting",
            "min_area",
            "preprocess_blur",
            "ignore_white",
            "output_to_swatches"
          ],
          "properties": {
            "max_colors": { "type": "integer", "minimum": 2, "maximum": 256 },
            "path_fitting": { "type": "number", "minimum": 0, "maximum": 10 },
            "min_area": { "type": "integer", "minimum": 1, "maximum": 1000 },
            "preprocess_blur": { "type": "number", "minimum": 0, "maximum": 2 },
            "ignore_white": { "type": "boolean" },
            "output_to_swatches": { "type": "boolean" }
          }
        },
        "preprocess": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "photoshop_preprocess",
            "normalize_srgb",
            "max_dimension",
            "median_radius"
          ],
          "properties": {
            "photoshop_preprocess": { "type": "boolean" },
            "normalize_srgb": { "type": "boolean" },
            "max_dimension": { "type": "integer", "minimum": 256, "maximum": 8192 },
            "median_radius": { "type": "integer", "minimum": 0, "maximum": 5 }
          }
        }
      }
    }
  }
}
