{
    "$schema":  "https://json-schema.org/draft/2020-12/schema",
    "title":  "WorldForge Offline Agent Task v0.1",
    "type":  "object",
    "additionalProperties":  false,
    "required":  [
                     "task_id",
                     "title",
                     "map",
                     "mode",
                     "command",
                     "actor_limit",
                     "build_limit_per_step",
                     "checkpoint_required",
                     "allow_external_assets",
                     "allow_network",
                     "allow_delete_non_worldforge_actor",
                     "pie_test_seconds",
                     "quality_mode"
                 ],
    "properties":  {
                       "task_id":  {
                                       "type":  "string",
                                       "pattern":  "^[0-9]{3}$"
                                   },
                       "title":  {
                                     "type":  "string",
                                     "minLength":  1,
                                     "maxLength":  80
                                 },
                       "map":  {
                                   "const":  "M_WorldForgeBlockoutSandbox"
                               },
                       "mode":  {
                                    "const":  "preview_then_execute"
                                },
                       "command":  {
                                       "enum":  [
                                                    "PreviewCityUpgrade",
                                                    "ExecuteCityUpgrade",
                                                    "CreateCheckpoint",
                                                    "RestoreLastCheckpoint",
                                                    "GenerateWorldSummary",
                                                    "RunPIESmokeTest",
                                                    "StopCurrentTask"
                                                ]
                                   },
                       "actor_limit":  {
                                           "type":  "integer",
                                           "minimum":  1,
                                           "maximum":  60
                                       },
                       "build_limit_per_step":  {
                                                    "type":  "integer",
                                                    "minimum":  1,
                                                    "maximum":  15
                                                },
                       "checkpoint_required":  {
                                                   "const":  true
                                               },
                       "allow_external_assets":  {
                                                     "const":  false
                                                 },
                       "allow_network":  {
                                             "const":  false
                                         },
                       "allow_delete_non_worldforge_actor":  {
                                                            "const":  false
                                                        },
                       "pie_test_seconds":  {
                                                "type":  "integer",
                                                "minimum":  1,
                                                "maximum":  20
                                            },
                       "quality_mode":  {
                                            "const":  "low_load"
                                        },
                       "notes":  {
                                     "type":  "string",
                                     "maxLength":  500
                                 }
                   }
}
