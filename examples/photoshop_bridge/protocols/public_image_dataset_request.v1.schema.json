{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://starbridge.local/schemas/public_image_dataset_request.v1.schema.json",
  "title": "StarBridge Public Image Dataset Request v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "provider", "max_width", "items"],
  "properties": {
    "schema_version": {"const": "starbridge.public_image_dataset_request.v1"},
    "provider": {"const": "wikimedia_commons"},
    "max_width": {"type": "integer", "minimum": 320, "maximum": 2048},
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "file_title", "expected_license_family", "use_case"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"
          },
          "file_title": {
            "type": "string",
            "pattern": "^File:",
            "maxLength": 256
          },
          "expected_license_family": {
            "enum": ["public_domain", "cc0", "cc_by", "cc_by_sa"]
          },
          "use_case": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"
          }
        }
      }
    }
  }
}
