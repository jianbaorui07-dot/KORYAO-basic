{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.koryao.local/model-contract/v1/common.schema.json",
  "title": "KORYAO Model Contract v1 Common Types",
  "$defs": {
    "contractVersion": {
      "type": "string",
      "const": "koryao-model-contract/v1"
    },
    "safeId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,95}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "semanticVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "shortText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[^\\r\\n\\u0000-\\u001F\\u007F]+$"
    },
    "instructionText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "mediaType": {
      "type": "string",
      "maxLength": 127,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9!#$&^_.+-]*/[A-Za-z0-9][A-Za-z0-9!#$&^_.+-]*$"
    },
    "scalarValue": {
      "oneOf": [
        {
          "type": "string",
          "maxLength": 512,
          "pattern": "^[^\\r\\n\\u0000-\\u001F\\u007F]*$"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "maxLength": 128,
            "pattern": "^[^\\r\\n\\u0000-\\u001F\\u007F]+$"
          }
        }
      ]
    },
    "assetRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assetId",
        "mediaType",
        "role",
        "sha256"
      ],
      "properties": {
        "assetId": {
          "$ref": "#/$defs/safeId"
        },
        "mediaType": {
          "$ref": "#/$defs/mediaType"
        },
        "role": {
          "enum": [
            "source",
            "reference",
            "mask",
            "result",
            "evidence"
          ]
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "adapterAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "requiresConfirmation",
        "sideEffect"
      ],
      "properties": {
        "action": {
          "$ref": "#/$defs/safeId"
        },
        "sideEffect": {
          "enum": [
            "read",
            "plan",
            "write"
          ]
        },
        "requiresConfirmation": {
          "type": "boolean"
        }
      }
    },
    "availableAdapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actions",
        "adapterId",
        "connectionState"
      ],
      "properties": {
        "adapterId": {
          "$ref": "#/$defs/safeId"
        },
        "connectionState": {
          "enum": [
            "unknown",
            "not_installed",
            "available",
            "not_running",
            "connected",
            "error"
          ]
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/adapterAction"
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cloudProcessingApproved",
        "embeddedRasterAllowed",
        "executionMode",
        "localOnly",
        "materialTransfer",
        "maxSteps",
        "outputFormats",
        "requireConfirmationForWrites",
        "safeRootRefs"
      ],
      "properties": {
        "executionMode": {
          "enum": [
            "local",
            "cloud"
          ]
        },
        "localOnly": {
          "type": "boolean"
        },
        "cloudProcessingApproved": {
          "type": "boolean"
        },
        "materialTransfer": {
          "enum": [
            "none",
            "metadata_only",
            "user_approved_assets"
          ]
        },
        "embeddedRasterAllowed": {
          "type": "boolean"
        },
        "outputFormats": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/safeId"
          }
        },
        "requireConfirmationForWrites": {
          "const": true
        },
        "maxSteps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "safeRootRefs": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/safeId"
          }
        }
      }
    },
    "privacyDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "absolutePathsIncluded",
        "customerFileNamesIncluded",
        "rawAssetContentIncluded"
      ],
      "properties": {
        "absolutePathsIncluded": {
          "const": false
        },
        "customerFileNamesIncluded": {
          "const": false
        },
        "rawAssetContentIncluded": {
          "const": false
        }
      }
    },
    "stepParameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/safeId"
        },
        "value": {
          "$ref": "#/$defs/scalarValue"
        }
      }
    },
    "plannedStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "adapterId",
        "dependsOn",
        "inputRefs",
        "parameters",
        "requiresConfirmation",
        "stepId"
      ],
      "properties": {
        "stepId": {
          "$ref": "#/$defs/safeId"
        },
        "adapterId": {
          "$ref": "#/$defs/safeId"
        },
        "action": {
          "$ref": "#/$defs/safeId"
        },
        "dependsOn": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/safeId"
          }
        },
        "inputRefs": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/safeId"
          }
        },
        "parameters": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/stepParameter"
          }
        },
        "requiresConfirmation": {
          "type": "boolean"
        },
        "safeRootRef": {
          "$ref": "#/$defs/safeId"
        }
      }
    },
    "qualityTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric",
        "operator",
        "value"
      ],
      "properties": {
        "metric": {
          "$ref": "#/$defs/safeId"
        },
        "operator": {
          "enum": [
            "eq",
            "ne",
            "gte",
            "lte",
            "contains"
          ]
        },
        "value": {
          "$ref": "#/$defs/scalarValue"
        },
        "unit": {
          "$ref": "#/$defs/safeId"
        }
      }
    },
    "evidenceMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric",
        "passed",
        "value"
      ],
      "properties": {
        "metric": {
          "$ref": "#/$defs/safeId"
        },
        "value": {
          "$ref": "#/$defs/scalarValue"
        },
        "target": {
          "$ref": "#/$defs/scalarValue"
        },
        "unit": {
          "$ref": "#/$defs/safeId"
        },
        "passed": {
          "type": "boolean"
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "severity"
      ],
      "properties": {
        "code": {
          "$ref": "#/$defs/safeId"
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "message": {
          "$ref": "#/$defs/shortText"
        },
        "stepId": {
          "$ref": "#/$defs/safeId"
        }
      }
    },
    "responseSafety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confirmationGateBypass",
        "directExecution",
        "directFileAccess",
        "shellCommandsIncluded"
      ],
      "properties": {
        "confirmationGateBypass": {
          "const": false
        },
        "directExecution": {
          "const": false
        },
        "directFileAccess": {
          "const": false
        },
        "shellCommandsIncluded": {
          "const": false
        }
      }
    }
  }
}
