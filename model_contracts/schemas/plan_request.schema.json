{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.koryao.local/model-contract/v1/plan_request.schema.json",
  "title": "KORYAO Plan Request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "availableAdapters",
    "constraints",
    "inputAssets",
    "instruction",
    "privacy",
    "projectId",
    "requestId",
    "schema"
  ],
  "properties": {
    "schema": {
      "$ref": "common.schema.json#/$defs/contractVersion"
    },
    "requestId": {
      "$ref": "common.schema.json#/$defs/safeId"
    },
    "projectId": {
      "$ref": "common.schema.json#/$defs/safeId"
    },
    "instruction": {
      "$ref": "common.schema.json#/$defs/instructionText"
    },
    "locale": {
      "type": "string",
      "pattern": "^[a-z]{2}(?:-[A-Z]{2})?$"
    },
    "inputAssets": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "$ref": "common.schema.json#/$defs/assetRef"
      }
    },
    "availableAdapters": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "$ref": "common.schema.json#/$defs/availableAdapter"
      }
    },
    "constraints": {
      "$ref": "common.schema.json#/$defs/constraints"
    },
    "privacy": {
      "$ref": "common.schema.json#/$defs/privacyDeclaration"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "constraints": {
            "properties": {
              "executionMode": {
                "const": "local"
              }
            },
            "required": [
              "executionMode"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "constraints": {
            "properties": {
              "cloudProcessingApproved": {
                "const": false
              },
              "localOnly": {
                "const": true
              },
              "materialTransfer": {
                "enum": [
                  "none",
                  "metadata_only"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "constraints": {
            "properties": {
              "executionMode": {
                "const": "cloud"
              }
            },
            "required": [
              "executionMode"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "constraints": {
            "properties": {
              "cloudProcessingApproved": {
                "const": true
              },
              "localOnly": {
                "const": false
              },
              "materialTransfer": {
                "enum": [
                  "metadata_only",
                  "user_approved_assets"
                ]
              }
            }
          }
        }
      }
    }
  ]
}
