{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://starbridge.local/schemas/capability-status.v1.json",
  "title": "CreNexus Capability Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "capabilityStatus",
    "evidenceLevel",
    "recommended",
    "deprecated"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "capabilityStatus": {
      "enum": ["stable", "experimental", "planned", "not_implemented"]
    },
    "evidenceLevel": {
      "enum": ["none", "schema", "unit", "integration", "local_app", "release"]
    },
    "connectionState": {
      "enum": ["unknown", "not_installed", "available", "not_running", "connected", "error"]
    },
    "recommended": { "type": "boolean" },
    "deprecated": { "type": "boolean" },
    "lastVerifiedAt": { "type": ["string", "null"], "format": "date-time" },
    "evidenceRefs": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  }
}
