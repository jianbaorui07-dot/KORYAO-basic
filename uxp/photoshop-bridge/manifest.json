{
  "manifestVersion": 5,
  "id": "com.starbridge.photoshop.bridge",
  "name": "StarBridge Photoshop Bridge",
  "version": "1.2.0",
  "main": "src/index.js",
  "host": {
    "app": "PS",
    "minVersion": "25.0.0"
  },
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "network": {
      "domains": [
        "ws://127.0.0.1:8971",
        "http://127.0.0.1:8971"
      ]
    }
  },
  "entrypoints": [
    {
      "type": "command",
      "id": "starbridgePing",
      "label": "StarBridge Ping"
    }
  ]
}
