{
  "manifestVersion": 5,
  "id": "com.starbridge.photoshop.bridge",
  "name": "StarBridge Photoshop Bridge",
  "version": "1.3.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "25.0.0"
  },
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "network": {
      "domains": [
        "ws://127.0.0.1:8971",
        "http://127.0.0.1:8971"
      ]
    }
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "starbridgePhotoshopLivePanel",
      "label": {"default": "Codex Live"},
      "minimumSize": {"width": 260, "height": 220},
      "preferredDockedSize": {"width": 300, "height": 360},
      "preferredFloatingSize": {"width": 340, "height": 400}
    },
    {
      "type": "command",
      "id": "starbridgePing",
      "label": "StarBridge Ping"
    }
  ]
}
