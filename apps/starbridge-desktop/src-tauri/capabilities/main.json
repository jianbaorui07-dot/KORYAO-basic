{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Minimum capability set for the CreNexus main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/starbridge-sidecar",
          "sidecar": true,
          "args": [
            "--desktop",
            "--parent-pid",
            {
              "validator": "^[1-9][0-9]{0,9}$"
            }
          ]
        }
      ]
    }
  ]
}
