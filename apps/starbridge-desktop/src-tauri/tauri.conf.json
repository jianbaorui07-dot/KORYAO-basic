{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StarBridge Desktop",
  "version": "0.1.0",
  "identifier": "io.starbridge.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "StarBridge",
        "width": 1120,
        "height": 760,
        "minWidth": 780,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost",
      "capabilities": ["main"]
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/starbridge-sidecar"],
    "resources": {
      "binaries/_internal/": "_internal/"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
