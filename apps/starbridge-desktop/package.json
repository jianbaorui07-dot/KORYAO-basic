{
  "name": "@starbridge/desktop",
  "version": "0.1.0-alpha.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run && npm run test:tauri-config",
    "test:watch": "vitest",
    "test:tauri-config": "node --test scripts/check-tauri-config.node-tests.mjs && node scripts/check-tauri-config.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --no-bundle",
    "tauri:bundle:nsis": "tauri build --bundles nsis"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.45.0",
    "@tauri-apps/api": "^2.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "happy-dom": "^20.8.9",
    "typescript": "^5.8.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.0"
  }
}
